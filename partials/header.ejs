<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<nav class="navbar">
  <div class="container navbar-shell">
    <div class="navbar-brand">
      <a href="/">
        <img src="/images/kundu-cafe-logo.svg" alt="Kundu Cafe logo" class="brand-logo">
        <span class="brand-text">
          <strong>Kundu Cafe</strong>
          <small>Campus Kitchen</small>
        </span>
      </a>
    </div>

    <div class="navbar-menu">
      <a href="/products"><i class="bi bi-grid-3x3-gap-fill nav-icon"></i>Products</a>
      <a href="/cart"><i class="bi bi-bag-heart-fill nav-icon"></i>Cart</a>
      <% if (user) { %>
        <a href="/orders"><i class="bi bi-receipt-cutoff nav-icon"></i>Orders</a>
        <a href="/wallet"><i class="bi bi-wallet2 nav-icon"></i>Wallet</a>
        <% if (user.role === 'admin') { %>
          <a href="/admin"><i class="bi bi-speedometer2 nav-icon"></i>Admin</a>
        <% } %>
        <span class="user-badge"><%= user.username %> · <%= user.role %></span>
        <a href="/auth/logout"><i class="bi bi-box-arrow-right nav-icon"></i>Logout</a>
      <% } else { %>
        <a href="/auth/login"><i class="bi bi-person-circle nav-icon"></i>Login</a>
        <a href="/auth/admin/login"><i class="bi bi-shield-lock nav-icon"></i>Admin</a>
        <a href="/auth/signup"><i class="bi bi-person-plus-fill nav-icon"></i>Signup</a>
      <% } %>
    </div>
  </div>
</nav>

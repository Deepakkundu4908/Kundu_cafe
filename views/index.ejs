<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kundu Cafe</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container page-shell mt-4">
    <section class="menu-hero home-hero mb-4">
      <h1><i class="bi bi-cup-hot-fill me-2"></i>Welcome to Kundu Cafe</h1>
      <p>Fast, fresh, and flavorful meals for your campus day.</p>

      <% if (user) { %>
        <div class="hero-cta mt-3">
          <span class="hero-note"><i class="bi bi-person-heart me-1"></i>Welcome back, <strong><%= user.username %></strong></span>
          <a href="/products/menu" class="btn btn-light btn-lg"><i class="bi bi-grid-fill me-1"></i>Browse Menu</a>
        </div>
      <% } else { %>
        <p class="mt-3 mb-3">Join our campus community for quick and convenient food ordering.</p>
        <div class="hero-cta">
          <a href="/auth/login" class="btn btn-light btn-lg"><i class="bi bi-person-circle me-1"></i>Login</a>
          <a href="/auth/signup" class="btn btn-outline-light btn-lg"><i class="bi bi-person-plus-fill me-1"></i>Sign Up</a>
        </div>
      <% } %>
    </section>

    <% if (user) { %>
      <section class="menu-panel mb-4">
        <h3 class="page-subtitle"><i class="bi bi-stars me-2"></i>Your Frequent Orders</h3>
        <div id="frequentOrdersContainer" class="frequent-orders-container">
          <p class="text-muted mb-0">Loading your favorite items...</p>
        </div>
      </section>

      <section class="mb-4">
        <h3 class="page-subtitle"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Quick Categories</h3>
        <div class="row g-3 mt-1">
          <div class="col-6 col-md-3">
            <div class="card text-center h-100 category-tile" onclick="window.location.href='/products/menu?category=Breakfast'">
              <div class="card-body">
                <h5 class="tile-icon"><i class="bi bi-sunrise-fill"></i></h5>
                <h6 class="card-title">Breakfast</h6>
                <p class="text-muted small mb-0">Fresh morning picks</p>
              </div>
            </div>
          </div>

          <div class="col-6 col-md-3">
            <div class="card text-center h-100 category-tile" onclick="window.location.href='/products/menu?category=Lunch'">
              <div class="card-body">
                <h5 class="tile-icon"><i class="bi bi-egg-fried"></i></h5>
                <h6 class="card-title">Lunch</h6>
                <p class="text-muted small mb-0">Hearty meal bowls</p>
              </div>
            </div>
          </div>

          <div class="col-6 col-md-3">
            <div class="card text-center h-100 category-tile" onclick="window.location.href='/products/menu?category=Snacks'">
              <div class="card-body">
                <h5 class="tile-icon"><i class="bi bi-cake2-fill"></i></h5>
                <h6 class="card-title">Snacks</h6>
                <p class="text-muted small mb-0">Crunch and munch</p>
              </div>
            </div>
          </div>

          <div class="col-6 col-md-3">
            <div class="card text-center h-100 category-tile" onclick="window.location.href='/products/menu?category=Drinks'">
              <div class="card-body">
                <h5 class="tile-icon"><i class="bi bi-cup-straw"></i></h5>
                <h6 class="card-title">Drinks</h6>
                <p class="text-muted small mb-0">Hot and chilled cups</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    <% } else { %>
      <section class="mb-4">
        <h3 class="page-subtitle"><i class="bi bi-gem me-2"></i>Featured Categories</h3>
        <div class="row g-4 mt-1">
          <div class="col-md-6">
            <div class="card h-100 category-hero-card" onclick="window.location.href='/auth/login'">
              <div class="category-hero-visual visual-breakfast"><i class="bi bi-sunrise-fill"></i></div>
              <div class="card-body text-center">
                <h5 class="card-title">Delicious Breakfast</h5>
                <p class="text-muted mb-0">Start your day with fresh and filling options.</p>
              </div>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card h-100 category-hero-card" onclick="window.location.href='/auth/login'">
              <div class="category-hero-visual visual-drinks"><i class="bi bi-cup-hot-fill"></i></div>
              <div class="card-body text-center">
                <h5 class="card-title">Premium Beverages</h5>
                <p class="text-muted mb-0">Refresh with handcrafted drinks served fast.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="menu-panel text-center mb-4">
        <h5><i class="bi bi-bag-heart-fill me-2"></i>Ready to order?</h5>
        <p class="mb-3">Sign up with your college email and place your first order.</p>
        <a href="/auth/signup" class="btn btn-primary"><i class="bi bi-person-plus-fill me-1"></i>Create Account</a>
      </section>
    <% } %>

    <section class="menu-panel how-it-works mb-2">
      <h3 class="page-subtitle"><i class="bi bi-list-check me-2"></i>How It Works</h3>
      <div class="row mt-1 g-3">
        <div class="col-md-4 text-center">
          <div class="step-icon"><i class="bi bi-phone"></i></div>
          <h6>Browse Menu</h6>
          <p class="text-muted small mb-0">Choose from fresh items across categories.</p>
        </div>
        <div class="col-md-4 text-center">
          <div class="step-icon"><i class="bi bi-clock-history"></i></div>
          <h6>Select Pickup Time</h6>
          <p class="text-muted small mb-0">Pick a slot that suits your schedule.</p>
        </div>
        <div class="col-md-4 text-center">
          <div class="step-icon"><i class="bi bi-check2-circle"></i></div>
          <h6>Pick It Up</h6>
          <p class="text-muted small mb-0">Your order is ready at the counter on time.</p>
        </div>
      </div>
    </section>
  </div>

  <script>
  <% if (user) { %>
  async function loadFrequentOrders() {
    try {
      const response = await fetch('/products/frequent');
      const items = await response.json();
      const container = document.getElementById('frequentOrdersContainer');

      if (!items || items.length === 0) {
        container.innerHTML = '<p class="text-muted mb-0">Browse and order to build your favorites.</p>';
        return;
      }

      container.innerHTML = items.map(item => `
        <div class="frequent-item-card text-center">
          <div class="tile-icon mb-2">
            ${item.category === 'Breakfast' ? '<i class="bi bi-sunrise-fill"></i>' :
              item.category === 'Lunch' ? '<i class="bi bi-egg-fried"></i>' :
              item.category === 'Snacks' ? '<i class="bi bi-cake2-fill"></i>' : '<i class="bi bi-cup-hot-fill"></i>'}
          </div>
          <h6 class="mb-1">${item.name}</h6>
          <p class="text-muted small mb-2">₹${item.price}</p>
          <button class="btn btn-sm btn-success" onclick="quickAddToCart(${item.id}, '${item.name}')">
            <i class="bi bi-bag-plus-fill me-1"></i>Add to Cart
          </button>
        </div>
      `).join('');
    } catch (error) {
      console.error('Error loading frequent orders:', error);
    }
  }

  function quickAddToCart(itemId, itemName) {
    fetch('/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ itemId, quantity: 1 })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        alert(`${itemName} added to cart!`);
        window.location.href = '/checkout';
      }
    })
    .catch(error => console.error('Error:', error));
  }

  document.addEventListener('DOMContentLoaded', loadFrequentOrders);
  <% } %>
  </script>

  <%- include('../partials/footer') %>
</body>
</html>

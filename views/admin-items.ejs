<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Items - Kundu Cafe</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container page-shell admin-container">
    <h1>🍲 Menu Editor & Stock Management</h1>

    <% if (editMode && item) { %>
      <h2>Edit <%= item.name %></h2>
      <form method="POST" action="/admin/items/<%= item.id %>/update" class="admin-form" enctype="multipart/form-data">
        <div class="form-group">
          <label>Name:</label>
          <input type="text" name="name" value="<%= item.name %>" required>
        </div>
        <div class="form-group">
          <label>Category:</label>
          <input type="text" name="category" value="<%= item.category %>" required>
        </div>
        <div class="form-group">
          <label>Price (₹):</label>
          <input type="number" name="price" step="0.01" value="<%= item.price %>" required>
        </div>
        <div class="form-group">
          <label>Description:</label>
          <textarea name="description" required><%= item.description %></textarea>
        </div>
        <div class="form-group">
          <label>Image:</label>
          <input type="file" name="image" accept="image/*">
          <input type="hidden" name="image" value="<%= item.image %>">
          <small>Current: <%= item.image %></small>
        </div>
        <div class="form-group">
          <label>Quantity:</label>
          <input type="number" name="quantity" value="<%= item.quantity %>" required>
        </div>
        <div class="form-group">
          <label>Prep Time (min):</label>
          <input type="number" name="prepTime" value="<%= item.prepTime || '' %>">
        </div>
        <div class="form-group">
          <label>Seasonal:</label>
          <label class="switch">
            <input type="checkbox" name="subcategory" value="Seasonal" <%= item.subcategory === 'Seasonal' ? 'checked' : '' %>>
            <span class="slider"></span>
          </label>
        </div>
        <div class="form-actions">
          <a href="/admin/items" class="btn btn-secondary">Cancel</a>
          <button type="submit" class="btn btn-success">Save Changes</button>
        </div>
      </form>
    <% } else { %>
      <h2>Add Seasonal Item</h2>
      <form method="POST" action="/admin/items/add" class="admin-form" enctype="multipart/form-data">
        <div class="form-group">
          <label>Name:</label>
          <input type="text" name="name" required>
        </div>
        <div class="form-group">
          <label>Category:</label>
          <input type="text" name="category" required>
        </div>
        <div class="form-group">
          <label>Price (₹):</label>
          <input type="number" name="price" step="0.01" required>
        </div>
        <div class="form-group">
          <label>Description:</label>
          <textarea name="description" required></textarea>
        </div>
        <div class="form-group">
          <label>Image:</label>
          <input type="file" name="image" accept="image/*">
          <input type="text" name="image" placeholder="or URL">
        </div>
        <div class="form-group">
          <label>Quantity:</label>
          <input type="number" name="quantity" required>
        </div>
        <div class="form-group">
          <label>Prep Time (min):</label>
          <input type="number" name="prepTime">
        </div>
        <button type="submit" class="btn btn-success">Add Item</button>
      </form>
    <% } %>

    <h2>Current Items</h2>
    <% if (items && items.length > 0) { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Quantity</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td><%= item.id %></td>
              <td><%= item.name %></td>
              <td><%= item.category %> <%= item.subcategory ? `(${item.subcategory})` : '' %></td>
              <td>₹<%= item.price %></td>
              <td>
                <span class="status <%= item.isOutOfStock ? 'out-of-stock' : 'in-stock' %>">
                  <%= item.isOutOfStock ? 'Out of Stock' : 'In Stock' %>
                </span>
              </td>
              <td><%= item.quantity %></td>
              <td>
                <form method="POST" action="/admin/items/<%= item.id %>/toggle-stock" style="display:inline;">
                  <button type="submit" class="btn btn-sm <%= item.isOutOfStock ? 'btn-success' : 'btn-warning' %>">
                    <%= item.isOutOfStock ? 'Restock' : 'Out of Stock' %>
                  </button>
                </form>
                <a href="/admin/items/<%= item.id %>/edit" class="btn btn-sm btn-primary">Edit</a>
                <form method="POST" action="/admin/items/<%= item.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete <%= item.name %>?')">
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p>No items available.</p>
    <% } %>

    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io();
      socket.on('itemStockUpdate', (data) => {
        console.log('Stock update:', data);
        window.location.reload();
      });
    </script>
    <style>
      .status.in-stock {
        background: #d4edda;
        color: #155724;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
      }
      .status.out-of-stock {
        background: #f8d7da;
        color: #721c24;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
      }
      .switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 34px;
      }
      .switch input {
        opacity: 0;
        width: 0;
        height: 0;
      }
      .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 34px;
      }
      .slider:before {
        position: absolute;
        content: "";
        height: 26px;
        width: 26px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
      }
      input:checked + .slider {
        background-color: #2196F3;
      }
      input:checked + .slider:before {
        transform: translateX(26px);
      }
      .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
      }
    </style>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>

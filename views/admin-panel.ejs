<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - Kundu Cafe</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container page-shell admin-container">
    <h1>Admin Dashboard</h1>

    <div class="stats-grid">
      <div class="stat-card">
        <h3>Total Products</h3>
        <p class="stat-value"><%= totalItems %></p>
        <a href="/admin/items" class="btn btn-sm">Manage</a>
      </div>

      <div class="stat-card">
        <h3>Total Orders</h3>
        <p class="stat-value"><%= totalOrders %></p>
        <a href="/admin/orders" class="btn btn-sm">View All</a>
      </div>

      <div class="stat-card">
        <h3>Total Users</h3>
        <p class="stat-value"><%= totalUsers %></p>
      </div>
    </div>

    <h2>Recent Orders</h2>
    <% if (recentOrders && recentOrders.length > 0) { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>User ID</th>
            <th>Total</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% recentOrders.forEach(order => { %>
            <tr>
              <td><%= order.id %></td>
              <td><%= order.userId %></td>
              <td>₹<%= Math.round(order.totalPrice) %></td>
              <td><span class="status <%= order.status %>"><%= order.status %></span></td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p>No recent orders.</p>
    <% } %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>

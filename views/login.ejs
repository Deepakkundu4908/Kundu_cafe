<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Kundu Cafe</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container page-shell auth-container">
    <h1>Login</h1>
    <% if (typeof message !== 'undefined' && message) { %>
      <div class="error-message"><%= message %></div>
    <% } %>
    
    <form method="POST" action="/auth/login">
      <div class="form-group">
        <label for="email">Email (or College Email):</label>
        <input type="email" id="email" name="email" required>
      </div>
      
      <div class="form-group">
        <label for="password">Password:</label>
        <input type="password" id="password" name="password" required>
      </div>
      
      <button type="submit" class="btn btn-primary">Login</button>
    </form>
    
    <div class="auth-links">
      <p><a href="/auth/forgot-password">Forgot your password?</a></p>
      <p>Don't have an account? <a href="/auth/signup">Sign up here</a></p>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>

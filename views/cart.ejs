<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart - Kundu Cafe</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container page-shell">
    <h1>Shopping Cart</h1>

    <% if (cart && cart.length > 0) { %>
      <div class="cart-table">
        <table>
          <thead>
            <tr>
              <th>Item ID</th>
              <th>Quantity</th>
              <th>Price</th>
              <th>Subtotal</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach(item => { %>
              <tr>
                <td><%= item.id %></td>
                <td><%= item.quantity %></td>
                <td>₹<%= item.price %></td>
                <td>₹<%= (item.price * item.quantity) %></td>
                <td>
                  <form method="POST" action="/cart/remove/<%= item.id %>" style="display:inline;">
                    <button type="submit" class="btn btn-danger">Remove</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div class="cart-summary">
        <h3>Cart Summary</h3>
        <p>Total Items: <%= totalItems %></p>
        <p class="total-price">Total Price: ₹<%= Math.round(totalPrice) %></p>
      </div>

      <div class="cart-actions">
        <form method="POST" action="/orders/create" style="display:inline;">
          <button type="submit" class="btn btn-success">Proceed to Checkout</button>
        </form>
        <form method="POST" action="/cart/clear" style="display:inline;">
          <button type="submit" class="btn btn-danger">Clear Cart</button>
        </form>
      </div>
    <% } else { %>
      <p>Your cart is empty. <a href="/products">Continue shopping</a></p>
    <% } %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
